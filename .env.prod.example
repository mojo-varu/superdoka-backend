# Copy to .env.prod on VPS and fill in real values
# Never commit .env.prod

# Database — use a strong password, not logbuk123
DATABASE_URL=postgresql+asyncpg://postgres:CHANGE_ME@db:5432/logbuk_db

# Redis
REDIS_URL=redis://redis:6379/0

# Model paths — same as base compose, no change needed
CLASSIFIER_MODEL_PATH=/app/models/onnx/intent_classifier
NER_MODEL_PATH=/app/models/onnx/ner_extractor

# LLM — Ollama runs on VPS host, reachable via host.docker.internal
LLM_PROVIDER=ollama
LLM_BASE_URL=http://host.docker.internal:11434
LLM_MODEL=qwen2.5:3b-instruct
LLM_TIMEOUT_SECONDS=30
LLM_API_KEY=

# App
RULES_PATH=app/rules/fleet_rules.yaml
BOT_USERNAME=superdoka_bot
PYTHONPATH=/app
